# Server
HOST=0.0.0.0
PORT=1337
APP_KEYS=replaceWithFourRandomBase64Keys1,key2,key3,key4
API_TOKEN_SALT=replaceWithRandomBase64Salt
ADMIN_JWT_SECRET=replaceWithRandomBase64Secret
TRANSFER_TOKEN_SALT=replaceWithRandomBase64Salt
JWT_SECRET=replaceWithRandomBase64Secret

# Database (PostgreSQL)
DATABASE_CLIENT=postgres
DATABASE_HOST=127.0.0.1
DATABASE_PORT=5432
DATABASE_NAME=harvestwire
DATABASE_USERNAME=harvestwire_app
DATABASE_PASSWORD=changeme
DATABASE_SSL=false
DATABASE_SCHEMA=public

# Cloudinary (media optimization provider)
CLOUDINARY_NAME=your-cloud-name
CLOUDINARY_KEY=your-api-key
CLOUDINARY_SECRET=your-api-secret

# Frontend API token (generated in Strapi Admin > Settings > API Tokens)
# Give the Next.js frontend a "Read-only" token — see README "Frontend auth" section.
FRONTEND_READONLY_API_TOKEN=

# CORS — comma-separated list of allowed origins for the Next.js frontend(s)
CORS_ORIGINS=https://www.harvestwire.com,http://localhost:3000
